# GitHub Linguist Language Overrides
# Forces GitHub to display Python as the primary language (90%+)

# Ignore all generated HTML maps and presentation slides
*.html linguist-generated=true
*.html linguist-vendored=true

# Ignore large GeoJSON datasets, JSON, and CSV outputs


# Mark LaTeX scientific paper as documentation
*.tex linguist-documentation=true

# Ensure Python codebase is explicitly detected as primary language
main.py linguist-detectable=true
src/**/*.py linguist-detectable=true
main_workflow/**/*.py linguist-detectable=true
scripts/**/*.py linguist-detectable=true
tools/**/*.py linguist-detectable=true
